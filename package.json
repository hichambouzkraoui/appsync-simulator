{
  "name": "appsync-local-simulator",
  "version": "1.0.0",
  "description": "Local AWS AppSync simulator supporting VTL, JS resolvers, and Lambda/DynamoDB datasources",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "debug": "node --inspect src/server.js",
    "dev": "node --watch src/server.js",
    "dev:debug": "node --watch --inspect src/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.650.0",
    "@aws-sdk/lib-dynamodb": "^3.650.0",
    "@graphql-tools/schema": "^10.0.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "js-yaml": "^4.1.0",
    "velocityjs": "^2.0.6"
  }
}
