### ============================================
### MUTATIONS - JS Resolvers + NONE Datasource
### ============================================

### Update User (JS Resolver + NONE datasource)
POST http://localhost:4000/graphql
Content-Type: application/json

{
  "query": "mutation UpdateUser($id: ID!, $input: UpdateUserInput!) { updateUser(id: $id, input: $input) { id name email updatedAt } }",
  "variables": {
    "id": "user-1",
    "input": {
      "name": "Jane Doe",
      "email": "jane@example.com"
    }
  }
}

###

### Update User - Name Only
POST http://localhost:4000/graphql
Content-Type: application/json

{
  "query": "mutation UpdateUser($id: ID!, $input: UpdateUserInput!) { updateUser(id: $id, input: $input) { id name updatedAt } }",
  "variables": {
    "id": "user-1",
    "input": {
      "name": "Updated Name"
    }
  }
}

